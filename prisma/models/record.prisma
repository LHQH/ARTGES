model Record {
  id_record   Int      @id @default(autoincrement())
  file_name   String
  file_url    String
  type_estimate_bill_ String
  created_at  DateTime @default(now())

  id_client   Int?
  id_craftman Int?

  client   Client?   @relation(fields: [id_client], references: [id_client])
  craftman Craftman? @relation(fields: [id_craftman], references: [id_craftman])

  construct_sites Construct[]
}