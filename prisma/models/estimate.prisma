model Estimate {
    id_estimate     Int            @id @default(autoincrement())
    reference       String
    tva             Decimal
    status_estimate String
    created_at      DateTime       @default(now())
    id_craftman     Int?
    craftman        Craftman?      @relation(fields: [id_craftman], references: [id_craftman])
    id_client       Int?
    client          Client?        @relation(fields: [id_client], references: [id_client])
    bill            Bill[]
    estimateLine    EstimateLine[]
}
