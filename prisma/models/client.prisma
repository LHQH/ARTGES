model Client {
    id_client  Int      @id @default(autoincrement())
    lastName   String
    firstName  String
    email      String?  @unique
    phone      String?
    created_at DateTime @default(now())

    id_address Int?
    address    Address? @relation(fields: [id_address], references: [id_address])

    id_craftman Int?
    craftman    Craftman? @relation(fields: [id_craftman], references: [id_craftman])

    records         Record[]
    construct_sites Construct[]

    estimates Estimate[]
}