{% extends "../layouts/base.twig" %}


{% block style %}
	<link rel="stylesheet" href="/assets/css/styleDashboard.css">
{% endblock %}


{% block main %}
	{% include "../partials/navBar.twig" %}

	<div class="dashboardContent">
		<h2>Tableau de bord</h2>
		<p>Vue d’ensemble de votre activité</p>

		{# RAPID INFOS #}
		<section class="fastStat">
			<div class="statCard">
				<div class="statHeader">
					<p>Clients actif</p>
					<img src="" alt="iconeClient">
				</div>
				{# VARIABLE A NOMCLIENT !!!! #}
				<div class="statValue">3</div>
			</div>

			<div class="statCard">
				<div class="statHeader">
					<p>Chantier en cours</p>
					<img src="" alt="iconeHammer">
				</div>
				{# VARIABLE A CHANGER !!!! #}
				<div class="statValue">3</div>
			</div>

			<div class="statCard">
				<div class="statHeader">
					<p>Tâche en cours</p>
					<img src="" alt="iconePlanning">
				</div>
				{# VARIABLE A CHANGER !!!! #}
				<div class="statValue">2</div>
			</div>

			<div class="statCard">
				<div class="statHeader">
					<p>CA du mois</p>
					<img src="" alt="icone€">
				</div>
				{# VARIABLE A CHANGER !!!! #}
				<div class="statValue">30 000 €</div>
			</div>
		</section>

		{# CHANTIER DETAIL RAPID #}

		<section class="infoSection">
			<h3>Chantiers actifs</h3>


			{% for construct in constructs %}
				<div class="cardList">
					<article class="listItem">
						<div class="iteminfo">
							<h4>{{ construct.construct_name }}</h4>
							<p>{{ construct.client ? construct.client.firstName ~ ' ' ~ construct.client.lastName : 'Aucun client' }}</p>
						</div>
						<div class="priceDate">
							<p>
								{% if construct.bill %}
									<p>{{ construct.bill ? construct.bill.totalAmount : 'Pas de facture' }}</p>
									{% else %}

								{% endif %}
							</p>
							<p>Fin :
								{{ construct.end_date ? construct.end_date|date("d/m/Y") : '' }}</p>
						</div>
					</article>


				{% endfor %}
</section>


				{# VARIABLE A CHANGER !!!! #}

				{# <article class="listItem">


		

			{# RDV A VENIR #}
			<section
				class="nextDate">
				{# VARIABLE A CHANGER !!!! #}
				<h3>Prochaines interventions</h3>
				<article>
					<div>
						<p>11</p>
						<p>mars</p>
					</div>
					<div>
						<h3>Rénovation salle de bain</h3>
						<p>Démolition ancien carrelage</p>
					</div>

					<div>08:00 - 17:00</div>

				</article>


			</section>
		</div>
	{% endblock %}
