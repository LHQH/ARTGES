model Craftman {
    id_craftman   Int      @id @default(autoincrement())
    company_name  String?
    SIRET         String?
    socialReason  String?
    last_name     String?
    first_name    String?
    email         String?  @unique
    phone         String?
    logo_url      String
    hash_password String?
    created_at    DateTime @default(now())
    update_at     DateTime @updatedAt

    construct_sites ConstructSite[]
    events          Event[]
    records         Record[]
    clients         Client[]
    estimates       Estimate[]
    bills           Bill[]
    adress          Address[]
}
