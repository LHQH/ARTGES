model Estimate {
  id_estimate     Int      @id @default(autoincrement())
  reference       String
  issue_date      DateTime
  validity_date   DateTime
  status_estimate String
  created_at      DateTime @default(now())
  id_craftman Int?
  craftman Craftman? @relation(fields: [id_craftman], references: [id_craftman])
  bills Bill[]
}