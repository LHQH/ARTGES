<div class="header">
	<h1>DEVIS</h1>

	<div>
		Référence :
		{{ estimate.reference }}<br>
		Date :
		{{ estimate.created_at | date("d/m/Y") }}
	</div>
</div>
<div class="client">
	<h3>Client</h3>

	<p>
		{{ estimate.client.firstname }}
		{{ estimate.client.lastname }}<br>
		{{ estimate.client.email }}
	</p>
</div>
<table class="table">
	<thead>
		<tr>
			<th>Description</th>
			<th>Quantité</th>
			<th>Prix unitaire</th>
			<th>Total</th>
		</tr>
	</thead>

	<tbody>
		{% for line in estimate.estimateLines %}
			<tr>
				<td>{{ line.description }}</td>
				<td>{{ line.qty }}</td>
				<td>{{ line.unitAmount }}
					€</td>
				<td>{{ line.qty * line.unitAmount }}
					€</td>
			</tr>
		{% endfor %}
	</tbody>
</table>
<div class="totals">
	<p>TVA :
		{{ estimate.tva }}%</p>

	{% set totalHT = 0 %}

	{% for line in estimate.estimateLines %}
		{% set totalHT = totalHT + (line.qty * line.unitAmount) %}
	{% endfor %}

	<h3>Total HT :
		{{ totalHT }}
		€</h3>
	<h3>Total TTC :
		{{ totalHT * (1 + estimate.tva / 100) }}
		€</h3>
</div>
<div class="footer">
	Merci pour votre confiance
</div>
<div class="signature">
	Signature client
</div>

<style>

	body {
		font-family: Arial, sans-serif;
		font-size: 12px;
		padding: 40px;
		color: #000;
	}

	.header {
		display: flex;
		justify-content: space-between;
		margin-bottom: 30px;
	}

	.table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 20px;
	}

	.table th,
	.table td {
		border: 1px solid #000;
		padding: 8px;
	}

	.table th {
		background: #f2f2f2;
	}

	.totals {
		margin-top: 30px;
		text-align: right;
	}

	.footer {
		position: fixed;
		bottom: 20px;
		font-size: 10px;
		text-align: center;
		width: 100%;
	}
</style>
