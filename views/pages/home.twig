{% extends "../layouts/base.twig" %}

{% block style %}
	<link rel="stylesheet" href="/assets/css/styleHome.css">

{% endblock %}
{% block main %}
	{% include "../partials/header.twig" %}

	{# INTRO #}
	<section class="container">
		<h1>Gérer votre entreprise</h1>
		<h1 class="blueTitle">en toute simplicité</h1>
		<p>Fini les cahiers et les feuilles volantes ! ArtGes centralise la  gestion de vos clients,chantiers, planning et administratif en un seul  endroit. Plus de temps pour votre métier,moins pour la paperasse.</p>

		<button class="freeRegisterBtn">Démarrer gratuitement</button>
		{# INTRO PRESENTATION #}
		<div class="homeFeatures">
			<article class="card">
				<img class="iconeIntro" src="" alt="iconeClient">
				<h3>Base de données clients</h3>
				<p>Centralisez toutes les informations de vos clients</p>
			</article>


			<article class="card">
				<img class="iconeIntro" src="" alt="iconeConstruct">
				<h3>Gestion des chantiers</h3>
				<p>Suivez l'avancement de tous vos projets</p>
			</article>


			<article class="card">
				<img class="iconeIntro" src="" alt="iconePlanning">
				<h3>Planning intelligent</h3>
				<p>Organisez vos rendez-vous et interventions</p>
			</article>


			<article class="card">

				<img class="iconeIntro" src="" alt="iconeDoc">
				<h3>Devis et factures</h3>
				<p>Créez vos documents professionnels facilement</p>
			</article>


			<article class="card">
				<img class="iconeIntro" src="" alt="iconeCaddie">
				<h3>Suivi des achats</h3>
				<p>Gérez vos achats fournisseurs par chantier</p>
			</article>


		</div>


	</section>

	{# CCM DETAILS #}
	<section class="how-it-works">
		<h2 class="section-title">Comment ça marche ?</h2>
		<p class="section-subtitle">Trois étapes simples pour transformer votre gestion d'entreprise</p>

		<div class="steps-container">
			<div class="step-card">
				<div class="step-number">1</div>
				<h3>Inscrivez-vous gratuitement</h3>
				<p>Créez votre compte en quelques secondes</p>
			</div>
			<div class="step-card">
				<div class="step-number">2</div>
				<h3>Configurez votre entreprise</h3>
				<p>Ajoutez vos informations et votre logo</p>
			</div>
			<div class="step-card">
				<div class="step-number">3</div>
				<h3>Commencez à gérer</h3>
				<p>Clients, chantiers, devis, factures... tout est à portée de main</p>
			</div>
		</div>

		<article class="features-summary">
			<div class="feature-item">
				<div class="feature-icon blue-bg">📄</div>
				<div class="feature-text">
					<h3>Devis & Factures</h3>
					<p>Créez des devis et factures professionnels en quelques clics</p>
				</div>
			</div>

			<div class="feature-item">
				<div class="feature-icon blue-bg">📄</div>
				<div class="feature-text">
					<h3>Base de données clients</h3>
					<p>Centralisez toutes les informations de vos clients</p>
				</div>
			</div>

			<div class="feature-item">
				<div class="feature-icon blue-bg">📄</div>
				<div class="feature-text">
					<h3>Gestion des chantiers</h3>
					<p>Suivez l'avancement de tous vos projets</p>
				</div>
			</div>

			<div class="feature-item">
				<div class="feature-icon blue-bg">📄</div>
				<div class="feature-text">
					<h3>Planning intelligent</h3>
					<p>Organisez vos rendez-vous et interventions</p>
				</div>
			</div>

			<div class="feature-item">
				<div class="feature-icon blue-bg">📄</div>
				<div class="feature-text">
					<h3>Suivi des achats</h3>
					<p>Gérez vos achats fournisseurs par chantier</p>
				</div>
			</div>

		</div>
	</article>
</section>


{# PRICE CHOICE #}


{# FREE #}
<section class="pricing">
	<h2 class="section-title">Choisissez votre formule</h2>
	<p class="section-subtitle">Commencez gratuitement, évoluez quand vous le souhaitez</p>

	<div class="pricing-container">
		<article class="pricing-card">
			<div class="pricing-header-gray">Pour débuter</div>
			<div class="pricing-content">
				<h3 class="plan-name">GRATUIT</h3>
				<div class="price">0
					<span class="currency">€</span>
					<span class="period">/mois</span>
				</div>
				<p class="plan-desc">Parfait pour tester l'application...</p>

				<ul class="features-list">
					<li>
						<span class="check">✔</span>
						devis limité</li>
					<li>
						<span class="check">✔</span>
						factures limité</li>
					<li>
						<span class="check">✔</span>calendrier basique
					</li>
					<li>
						<span class="check">✔</span>personnalisationdes documents</li>
					<li>
						<span class="check">✔</span>10 clients maximum
					</li>

				</ul>
				<button class="btn-secondary">Commencer gratuitement</button>
			</div>
		</article>


{# PREMIUM #}
		<article class="pricing-card premium-card">
			<div class="badge-recommended">Recommandé</div>
			<div class="pricing-header-blue">Pour les professionnels</div>
			<div class="pricing-content">
				<h3 class="plan-name">Premium</h3>
				<div class="price">9
					<span class="currency">€</span>
					<span class="period">/mois</span>
				</div>
				<p class="plan-desc">Pour les artisans qui veulent professionnaliser leur gestion</p>

				<ul class="features-list">

					<li>
						<span class="check">✔</span>devis et factures illimités
					</li>
					<li>
						<span class="check">✔</span>relance automatique
					</li>
					<li>
						<span class="check">✔</span>exportation des documents
					</li>
					<li>
						<span class="check">✔</span>agenda avancé
					</li>
					<li>
						<span class="check">✔</span>clients illimités
					</li>

				</ul>

				<button class="btn-primary">Essayer 14 jours gratuits →</button>
			</div>
		</article>
	</div>
</section>{% endblock %}
