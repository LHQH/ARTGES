model Craftman {
    id_craftman  Int      @id @default(autoincrement())
    lastName     String?
    firstName    String?
    mail         String?  @unique
    phone        String?
    proAdress    String?
    postCode     String?
    city         String?
    SIRET        String?
    socialReason String?
    logo_url     String
    password     String?


    construct_sites Construct[]
    events          Event[]
    records         Record[]
    clients         Client[]
    estimates       Estimate[]
    bills           Bill[]
    adress          Address[]
}
